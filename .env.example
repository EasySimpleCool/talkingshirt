# Stripe secret key. In production, set this in the Netlify dashboard under
# Site configuration -> Environment variables. Locally, copy this file to
# `.env` and `netlify dev` will pick it up. Never commit the real key.
#
# Test key (starts with sk_test_) for development:
STRIPE_SECRET_KEY=sk_test_replace_me

# Webhook signing secret from Stripe Dashboard -> Developers -> Webhooks.
# Required for netlify/functions/stripe-webhook.js.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
