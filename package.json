{
  "name": "talkingshirt",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TalkingSh*rt — custom tees. Static site + Netlify Functions.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "build:site": "STORYBOOK_BASE=/storybook/ npm run build-storybook && rm -rf public/storybook && cp -r storybook-static public/storybook",
    "code-connect:publish": "figma connect publish",
    "design-audit": "node design-audit/run.mjs"
  },
  "dependencies": {
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.12",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/html-vite": "^10.4.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "vitest": "^4.1.7"
  }
}
