FIGMA_TOKEN=your_figma_personal_access_token_here

# Node IDs for the two audit targets (copy from the Figma URL ?node-id= param,
# replacing "-" with ":" — e.g. 123-456 → 123:456).
FIGMA_FILE_KEY=your_figma_file_key_here
FIGMA_NODE_MAIN=0:1        # production / shipping artboard
FIGMA_NODE_BENCH=0:2       # work-in-progress / bench artboard

# Optional — only needed for --llm-review mode in compare.py
ANTHROPIC_API_KEY=your_anthropic_api_key_here
