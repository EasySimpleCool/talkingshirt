# Copy to .env on each machine (personal Mac, work Mac, etc.):
#   cp design-audit/.env.example design-audit/.env
# Run the audit anytime:
#   npm run design-audit
# .env is gitignored — tokens stay local; they do not sync via git.
# File keys and node IDs can match on every machine; PAT values are per account.

# -----------------------------------------------------------------------------
# Personal account — design-audit (scan_figma.py, compare.py)
# -----------------------------------------------------------------------------
# Create at figma.com → avatar → Settings → Security → Personal access tokens.
# Scope: File content Read (minimum for scan_figma.py).
FIGMA_TOKEN=your_figma_personal_access_token_here

# main and bench are SEPARATE Figma files:
#   bench = staging file of ready-to-build components
#   main  = shipped components (move a component bench → main once built)
# The PAT in FIGMA_TOKEN must be able to read whichever file you scan.
#   npm run design-audit                 # scans main
#   npm run design-audit -- --target bench
FIGMA_FILE_KEY_MAIN=your_main_file_key_here
FIGMA_FILE_KEY_BENCH=your_bench_file_key_here

# Optional node IDs to scope a scan to one frame (copy from the Figma URL
# ?node-id= param, replacing "-" with ":" — e.g. 2-105 → 2:105).
# Leave blank to scan the whole file.
FIGMA_NODE_MAIN=
FIGMA_NODE_BENCH=

# -----------------------------------------------------------------------------
# Work account — Code Connect publish only (npm run code-connect:publish)
# -----------------------------------------------------------------------------
# Work org PAT. Scopes: Code Connect Write, File content Read.
# Not used by scan_figma.py — keep FIGMA_ACCESS_TOKEN separate from FIGMA_TOKEN.
FIGMA_ACCESS_TOKEN=your_figma_work_access_token_here

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Only needed for compare.py --llm-review
ANTHROPIC_API_KEY=your_anthropic_api_key_here
